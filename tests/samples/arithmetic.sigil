algebra StandardArithmetic

fn add int a + int b returns int
fn times int a * int b returns int
fn subtract int a - int b returns int
fn divide int a / int b returns int
fn negate - int a returns int

fn get mat m [ int i , int j ] returns int
fn set mat m [ int i , int j ] = int v returns void

fn range int a .. int b returns iter

fn span * returns range
  return do range 0 do length context end end

fn multiply int a @ int b returns int
  begin
    return do add do times a b end do times a b end end
  end

precedence + - * / @ ..
