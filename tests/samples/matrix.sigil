algebra MatrixArithmetic

rem Primitive sugar: bind sigils to built-in keywords
fn add int a + int b returns int
fn times int a * int b returns int
fn subtract int a - int b returns int
fn get mat m [ int i , int j ] returns int
fn set mat m [ int i , int j ] = int v returns void
fn range int a .. int b returns iter

rem Span: nullary sigil that expands to the full range of a dimension
fn span * returns iter
  return begin range 0 begin length context end end

rem Matrix literal sugar: row and matrix constructors via repeats
fn row [ int a , repeats ] returns mat
fn matrix [ mat a ; repeats ] returns mat

rem Dot product: sum of element-wise products across a shared dimension
fn dot mat a int row mat b int col int n returns int
  var acc 0
  for k in begin range 0 n end begin
    assign acc begin add acc begin times begin get a row k end begin get b k col end end end
  end
  return acc

rem Matrix multiply: comprehension over row/col pairs
fn multiply mat a @ mat b returns mat
  let rows begin length a end
  let cols begin length b end
  let n begin length a end
  collect from i in range 0 rows apply collect from j in range 0 cols apply dot a i b j n

rem Precedence: low to high
precedence + - * @ ..
