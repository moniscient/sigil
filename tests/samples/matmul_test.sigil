import "matrix.sigil"

use MatrixArithmetic

  rem Large matrix multiply: N x N times N x N
  rem N^3 dot product steps with hash-map-backed storage.
  rem N=750 gives ~70 seconds sequentially (no optimization).
  let N 750

  rem Build A: N x N matrix, A[i][j] = i + j + 1
  var A mapnew
  for i in range 0 N begin
    var row mapnew
    for j in range 0 N begin
      set row j (i + j + 1)
    end
    set A i row
  end

  rem Build B: N x N matrix of all ones
  var B mapnew
  for i in range 0 N begin
    var row mapnew
    for j in range 0 N begin
      set row j 1
    end
    set B i row
  end

  rem C = A @ B  (N x N result)
  rem Each C[i][j] = sum_{k=0}^{N-1} (i + k + 1)
  rem            = N*i + N*(N+1)/2
  rem For N=750: C[0][0]   = 750*751/2         = 281625
  rem           C[374][374] = 750*374 + 281625  = 562125
  rem           C[749][749] = 750*749 + 281625  = 843375
  var C mapnew
  C = (A @ B)

  rem Spot-check results
  print (get C 0 0)
  print (get C 374 374)
  print (get C 749 749)

  rem Verify
  var bad 0
  if not (equal (get C 0 0) 281625) {
    bad = (bad + 1)
  }
  if not (equal (get C 374 374) 562125) {
    bad = (bad + 1)
  }
  if not (equal (get C 749 749) 843375) {
    bad = (bad + 1)
  }
  print bad
